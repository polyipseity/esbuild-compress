{
  "chat.tools.terminal.autoApprove": {
    "/^-?\\d+\\.\\.-?\\d+$/": true,
    "/^(?:bun|npm|pnpm)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+(?:ci|help|install|test)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^(?:bun|pnpm)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*(?:\\s+exec|\\s+x)?(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+(?:commitlint|eslint|markdownlint-cli2|prettier|pyright|tsc|vitest)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^(?:bun|pnpm)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*(?:\\s+run)?\\s+(?:build|check|commitlint|format|test)(?::[^\\s]*)?(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^(?:bunx|npm\\s+exec|npx|pnpx)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+(?:commitlint|eslint|markdownlint-cli2|prettier|pyright|tsc|vitest)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^npm\\s+run(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+(?:build|check|commitlint|format|test)(?::[^\\s]*)?(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^python(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+-m\\s+(?:pyright|pytest|ruff|rumdl)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^python(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+['\"]?(?:\\.[/\\\\])*\\.agents[/\\\\]skills(?:[/\\\\][^/\\\\'\"]+?)*\\.py['\"]?(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^uv\\s+(?:lock|sync)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^uv\\s+run(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+(?:pyright|pytest|ruff|rumdl)(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "/^uv\\s+run(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*\\s+['\"]?(?:\\.[/\\\\])*\\.agents[/\\\\]skills(?:[/\\\\][^/\\\\'\"]+?)*\\.py['\"]?(?:\\s+(?:--?[\\w-]+(?:=[^\\s]+)?|[^\\s]+))*$/": true,
    "ConvertFrom-Json": true,
    "ForEach-Object": true,
    "Get-Item": true,
    "git rev-parse": true,
    "Group-Object": true,
    "i": true,
    "i++": true,
    "Out-Null": true,
    "Pop-Location": true,
    "Push-Location": true,
    "pyright": true,
    "pytest": true,
    "ruff": true,
    "rumdl": true,
    "Test-Path": true,
    "type": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.sortJSON": "explicit",
    "source.organizeImports": "explicit",
    "source.sort.json": "explicit"
  },
  "editor.formatOnSave": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "files.associations": {
    ".prettierignore": "ignore"
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "json.schemaDownload.trustedDomains": {
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true,
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json": true
  },
  "markdown.validate.enabled": true
}
